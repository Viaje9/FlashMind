generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Provider {
  EMAIL
  GOOGLE
}

model User {
  id                     String                  @id @default(cuid())
  email                  String                  @unique
  passwordHash           String?
  primaryProvider        Provider                @default(EMAIL)
  timezone               String                  @default("Asia/Taipei")
  lastLoginAt            DateTime?
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  oauthAccounts          OAuthAccount[]
  sessions               Session[]
  decks                  Deck[]
  collectionItems        CollectionItem[]
  collectionChatSessions CollectionChatSession[]
}

model OAuthAccount {
  id           String    @id @default(cuid())
  userId       String
  provider     Provider
  providerId   String
  accessToken  String?
  refreshToken String?
  expiresAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerId])
}

model Session {
  id         String   @id @default(cuid())
  userId     String
  token      String   @unique
  userAgent  String?
  ipAddress  String?
  expiresAt  DateTime
  rememberMe Boolean  @default(false)
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Deck {
  id               String @id @default(cuid())
  name             String
  dailyNewCards    Int    @default(20)
  dailyReviewCards Int    @default(100)
  dailyResetHour   Int    @default(4)

  // FSRS 演算法參數（per-deck）
  learningSteps    String @default("1m,10m")
  relearningSteps  String @default("10m")
  requestRetention Float  @default(0.9)
  maximumInterval  Int    @default(36500)

  enableReverse Boolean @default(false)

  // 今日上限覆寫（隔天自動失效）
  overrideDate        DateTime?
  overrideNewCards    Int?
  overrideReviewCards Int?

  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  cards     Card[]
}

enum CardState {
  NEW
  LEARNING
  REVIEW
  RELEARNING
}

model Card {
  id        String        @id @default(cuid())
  front     String
  deckId    String
  deck      Deck          @relation(fields: [deckId], references: [id], onDelete: Cascade)
  meanings  CardMeaning[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  // FSRS 排程欄位（正向）
  state         CardState @default(NEW)
  due           DateTime?
  stability     Float?
  difficulty    Float?
  elapsedDays   Int       @default(0)
  scheduledDays Int       @default(0)
  reps          Int       @default(0)
  lapses        Int       @default(0)
  lastReview    DateTime?
  learningStep  Int       @default(0)

  // FSRS 排程欄位（反向）
  reverseState         CardState @default(NEW)
  reverseDue           DateTime?
  reverseStability     Float?
  reverseDifficulty    Float?
  reverseElapsedDays   Int       @default(0)
  reverseScheduledDays Int       @default(0)
  reverseReps          Int       @default(0)
  reverseLapses        Int       @default(0)
  reverseLastReview    DateTime?
  reverseLearningStep  Int       @default(0)

  reviewLogs      ReviewLog[]
  collectionLinks CollectionItemCard[]
}

model CardMeaning {
  id        String   @id @default(cuid())
  cardId    String
  card      Card     @relation(fields: [cardId], references: [id], onDelete: Cascade)
  zhMeaning String
  enExample String?
  zhExample String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum StudyRating {
  KNOWN
  UNFAMILIAR
  UNKNOWN
}

model ReviewLog {
  id         String      @id @default(cuid())
  cardId     String
  card       Card        @relation(fields: [cardId], references: [id], onDelete: Cascade)
  rating     StudyRating
  reviewedAt DateTime    @default(now())

  // 評分前的狀態
  prevState      CardState
  prevStability  Float?
  prevDifficulty Float?

  // 評分後的狀態
  newState      CardState
  newStability  Float?
  newDifficulty Float?
  scheduledDays Int

  // 學習方向
  direction String @default("FORWARD")
}

enum CollectionItemKind {
  SENTENCE
  COLLOCATION
  PHRASE
  CLAUSE
}

enum CollectionRelationType {
  SENTENCE_HAS_COLLOCATION
  SENTENCE_HAS_PHRASE
  SENTENCE_HAS_CLAUSE
  PHRASE_HAS_COLLOCATION
  CLAUSE_HAS_COLLOCATION
}

enum CollectionChatRole {
  USER
  ASSISTANT
}

model CollectionItem {
  id             String             @id @default(cuid())
  userId         String
  kind           CollectionItemKind
  text           String
  normalizedText String
  zhMeaning      String?
  note           String?
  createdFrom    String?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  user            User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  parentRelations CollectionItemRelation[] @relation("CollectionParent")
  childRelations  CollectionItemRelation[] @relation("CollectionChild")
  cardLinks       CollectionItemCard[]

  @@unique([userId, kind, normalizedText])
  @@index([userId, kind, createdAt])
  @@index([userId, normalizedText])
}

model CollectionItemRelation {
  id        String                 @id @default(cuid())
  parentId  String
  childId   String
  type      CollectionRelationType
  sortOrder Int                    @default(0)
  createdAt DateTime               @default(now())

  parent CollectionItem @relation("CollectionParent", fields: [parentId], references: [id], onDelete: Cascade)
  child  CollectionItem @relation("CollectionChild", fields: [childId], references: [id], onDelete: Cascade)

  @@unique([parentId, childId, type])
  @@index([childId])
}

model CollectionItemCard {
  id               String   @id @default(cuid())
  collectionItemId String
  cardId           String
  role             String
  createdAt        DateTime @default(now())

  collectionItem CollectionItem @relation(fields: [collectionItemId], references: [id], onDelete: Cascade)
  card           Card           @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@unique([collectionItemId, cardId, role])
  @@index([cardId])
}

model CollectionChatSession {
  id               String   @id @default(cuid())
  userId           String
  provider         String   @default("OPENAI_AGENTS")
  providerThreadId String?
  title            String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user     User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages CollectionChatMessage[]

  @@index([userId, updatedAt])
}

model CollectionChatMessage {
  id        String             @id @default(cuid())
  sessionId String
  role      CollectionChatRole
  content   String
  metadata  Json?
  createdAt DateTime           @default(now())

  session CollectionChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
}
